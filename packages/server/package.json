		"db:migrate": "drizzle-kit migrate"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1030.0",
		"@hono/node-server": "^1.19.14",
		"@hono/trpc-server": "^0.4.2",
		"@mdx-js/mdx": "^3.1.1",
		"@trpc/server": "^11.16.0",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"gray-matter": "^4.0.3",
		"hono": "^4.12.14",
		"jose": "^6.2.2",
		"pg": "^8.20.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@electric-sql/pglite": "^0.4.4",
		"@types/node": "^25.6.0",
		"@types/pg": "^8.20.0",
		"drizzle-kit": "^0.31.10",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4"
