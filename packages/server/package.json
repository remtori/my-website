{
	"name": "@website/server",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"files": ["dist", "src/db/migrations"],
	"scripts": {
		"dev": "tsx watch src/main.ts",
		"build": "tsup",
		"test": "vitest run",
		"test:watch": "vitest",
