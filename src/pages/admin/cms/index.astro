---
import Layout from '@/layouts/Layout.astro';

import { getFileIndex } from '@/lib/file-index';
import { getEnv } from '@/lib/runtime';

export const prerender = false;

const err = Astro.url.searchParams.get('err');
const deleted = Astro.url.searchParams.get('deleted');
const collision = Astro.url.searchParams.get('collision');

const env = getEnv();
const index = await getFileIndex(env);
const keys = index.map((e) => e.key).sort();
---

<Layout title="CMS">
	<h1 class="text-2xl font-bold text-white">Content (S3)</h1>
	<p class="mt-2 text-zinc-400">List, edit, or create objects under the <code class="text-amber-400">mdx/</code> prefix.</p>

	{err ? <p class="mt-4 text-sm text-red-400">Something went wrong (S3 or validation).</p> : null}
	{deleted ? <p class="mt-4 text-sm text-green-400">Object deleted.</p> : null}
	{collision ? <p class="mt-4 text-sm text-red-400">An object with that name already exists.</p> : null}

	<p class="mt-6">
		<a href="/admin/cms/new" class="text-amber-400 hover:underline">+ New MDX object</a>
	</p>

	<ul class="mt-6 space-y-2">
		{
			keys.length === 0 ? (
				<li class="text-zinc-500">No objects found. Configure S3 env vars or create a post.</li>
			) : (
				keys.map((k) => (
					<li class="flex flex-wrap items-center gap-2 border-b border-zinc-800 py-2 text-sm">
						<a class="text-amber-400 hover:underline" href={`/admin/cms/edit?key=${encodeURIComponent(k)}`}>
							{k}
						</a>
						<form method="POST" action="/api/admin/cms-delete" class="inline">
							<input type="hidden" name="key" value={k} />
							<button type="submit" class="text-xs text-red-400 hover:underline" onclick="return confirm('Delete this object?')">
								Delete
							</button>
						</form>
					</li>
				))
			)
		}
	</ul>
</Layout>
