---
import Layout from '@/layouts/Layout.astro';

export const prerender = false;
---

<Layout title="New MDX">
	<h1 class="text-2xl font-bold text-white">New MDX object</h1>

	<form method="POST" action="/api/admin/cms-save" class="mt-8 space-y-4">
		<label class="block text-sm text-zinc-300">
			Type
			<select name="type" id="type-select" class="mt-1 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-white outline-none focus:border-amber-500">
				<option value="blog">Blog post</option>
				<option value="page">Page</option>
			</select>
		</label>

		<label class="block text-sm text-zinc-300">
			Title
			<input
				name="title"
				id="title-input"
				required
				placeholder="My new post"
				class="mt-1 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 font-mono text-sm text-white outline-none focus:border-amber-500"
			/>
		</label>

		<p class="text-xs text-zinc-500">
			Key will be: <code id="derived-key" class="text-amber-400">mdx/blogs/{new Date().toISOString().slice(0, 10)}-my-new-post.mdx</code>
		</p>

		<label class="block text-sm text-zinc-300">
			Content
			<textarea name="content" required rows={18} class="mt-1 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 font-mono text-sm text-white outline-none focus:border-amber-500">{
				`---
title: New post
date: ${new Date().toISOString().slice(0, 10)}
---

Hello from **markdown**.`
			}</textarea>
		</label>

		<button type="submit" class="rounded-md bg-amber-500 px-4 py-2 font-medium text-zinc-950 hover:bg-amber-400"> Save to S3 </button>
	</form>

	<script is:inline>
		(function () {
			const typeSelect = document.getElementById('type-select');
			const titleInput = document.getElementById('title-input');
			const keyDisplay = document.getElementById('derived-key');

			function slugify(str) {
				return str
					.toLowerCase()
					.trim()
					.replace(/[^a-z0-9]+/g, '-')
					.replace(/^-+|-+$/g, '');
			}

			function updateKey() {
				const title = titleInput.value || 'my-new-post';
				const slug = slugify(title);
				const type = typeSelect.value;
				if (type === 'blog') {
					const date = new Date().toISOString().slice(0, 10);
					keyDisplay.textContent = 'mdx/blogs/' + date + '-' + slug + '.mdx';
				} else {
					keyDisplay.textContent = 'mdx/' + slug + '.mdx';
				}
			}

			typeSelect.addEventListener('change', updateKey);
			titleInput.addEventListener('input', updateKey);
			updateKey();
		})();
	</script>
</Layout>
