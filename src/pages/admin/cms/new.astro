---
import Layout from '@/layouts/Layout.astro';
import PageHeader from '@/components/PageHeader.astro';

export const prerender = false;
---

<Layout title="New MDX">
	<PageHeader title="New MDX object" subtitle="Create a new post or page in S3." />

	<form method="POST" action="/api/admin/cms-save" class="animate-fade-in-up animate-delay-100 mt-8 space-y-5">
		<label class="block text-sm text-text-secondary">
			<span class="mb-1.5 block font-medium">Type</span>
			<select
				name="type"
				id="type-select"
				class="w-full border-2 border-border bg-bg-base px-4 py-3 text-sm text-text-primary outline-none transition focus:border-accent"
			>
				<option value="blog">Blog post</option>
				<option value="page">Page</option>
			</select>
		</label>

		<label class="block text-sm text-text-secondary">
			<span class="mb-1.5 block font-medium">Title</span>
			<input
				name="title"
				id="title-input"
				required
				placeholder="My new post"
				class="w-full border-2 border-border bg-bg-base px-4 py-3 font-mono text-sm text-text-primary outline-none transition focus:border-accent"
			/>
		</label>

		<p class="font-mono text-xs text-text-muted">
			Key will be: <code id="derived-key" class="bg-bg-subtle px-2 py-0.5 font-mono text-accent">mdx/blogs/{new Date().toISOString().slice(0, 10)}-my-new-post.mdx</code>
		</p>

		<label class="block text-sm text-text-secondary">
			<span class="mb-1.5 block font-medium">Content</span>
			<textarea
				name="content"
				required
				rows={18}
				class="w-full border-2 border-border bg-bg-base px-4 py-3 font-mono text-sm text-text-primary outline-none transition focus:border-accent"
			>{
				`---
title: New post
date: ${new Date().toISOString().slice(0, 10)}
---

Hello from **markdown**.`
			}</textarea>
		</label>

		<div class="flex flex-wrap items-center gap-4 pt-1">
			<button
				type="submit"
				class="bg-accent px-6 py-3 font-display font-bold text-bg-base shadow-[4px_4px_0px_#b0882e] transition-all hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-[6px_6px_0px_#b0882e]"
			>
				Save to S3
			</button>
			<a href="/admin/cms" class="font-mono text-xs text-text-muted underline underline-offset-4 transition hover:text-text-secondary">← Back to list</a>
		</div>
	</form>

	<script is:inline>
		(function () {
			const typeSelect = document.getElementById('type-select');
			const titleInput = document.getElementById('title-input');
			const keyDisplay = document.getElementById('derived-key');

			function slugify(str) {
				return str
					.toLowerCase()
					.trim()
					.replace(/[^a-z0-9]+/g, '-')
					.replace(/^-+|-+$/g, '');
			}

			function updateKey() {
				const title = titleInput.value || 'my-new-post';
				const slug = slugify(title);
				const type = typeSelect.value;
				if (type === 'blog') {
					const date = new Date().toISOString().slice(0, 10);
					keyDisplay.textContent = 'mdx/blogs/' + date + '-' + slug + '.mdx';
				} else {
					keyDisplay.textContent = 'mdx/' + slug + '.mdx';
				}
			}

			typeSelect.addEventListener('change', updateKey);
			titleInput.addEventListener('input', updateKey);
			updateKey();
		})();
	</script>
</Layout>
