---
import Layout from '@/layouts/Layout.astro';

import { getObjectText } from '@/lib/s3';

export const prerender = false;

const key = Astro.url.searchParams.get('key');
const saved = Astro.url.searchParams.get('saved');

if (!key || key.includes('..') || !key.startsWith('mdx/')) {
	return Astro.redirect('/admin/cms', 302);
}

let content = '';
try {
	content = await getObjectText(key);
} catch {
	return Astro.redirect('/admin/cms?err=1', 302);
}
---

<Layout title="Edit MDX">
	<div class="animate-fade-in-up space-y-3">
		<h1 class="font-display text-4xl font-bold tracking-tight text-text-primary">Edit</h1>
		<div class="h-1 w-16 bg-accent"></div>
		<p class="font-mono text-sm text-text-muted">{key}</p>
	</div>

	{saved ? <p class="mt-5 border border-success/30 bg-success/5 px-4 py-3 font-mono text-sm text-success">Saved to S3. Purge cache for the public URL if needed.</p> : null}

	<form method="POST" action="/api/admin/cms-save" class="animate-fade-in-up animate-delay-100 mt-8 space-y-5">
		<input type="hidden" name="key" value={key} />
		<label class="block text-sm text-text-secondary">
			<span class="mb-1.5 block font-medium">Content</span>
			<textarea
				name="content"
				required
				rows={22}
				class="w-full border-2 border-border bg-bg-base px-4 py-3 font-mono text-sm text-text-primary outline-none transition focus:border-accent"
			>{content}</textarea>
		</label>
		<div class="flex flex-wrap items-center gap-4 pt-1">
			<button
				type="submit"
				class="bg-accent px-6 py-3 font-display font-bold text-bg-base shadow-[4px_4px_0px_#b0882e] transition-all hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-[6px_6px_0px_#b0882e]"
			>
				Save
			</button>
			<a href="/admin/cms" class="font-mono text-xs text-text-muted underline underline-offset-4 transition hover:text-text-secondary">← Back to list</a>
		</div>
	</form>
</Layout>
