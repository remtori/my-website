---
import Layout from '@/layouts/Layout.astro';

export const prerender = false;
---

<Layout title="Admin">
	<h1 class="text-2xl font-bold text-white">Dashboard</h1>
	<ul class="mt-8 space-y-3 text-amber-400">
		<li><a class="hover:underline" href="/admin/cms">CMS — edit MDX in S3</a></li>
		<li><a class="hover:underline" href="/admin/purge">Purge edge cache</a></li>
	</ul>
	<form method="POST" action="/api/admin/logout" class="mt-10">
		<button type="submit" class="text-sm text-zinc-500 underline hover:text-zinc-300"> Sign out </button>
	</form>
</Layout>
