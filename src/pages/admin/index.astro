---
import AdminLayout from '@/layouts/AdminLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import { getFileIndex } from '@/lib/file-index';

export const prerender = false;

const err = Astro.url.searchParams.get('err');
const deleted = Astro.url.searchParams.get('deleted');
const collision = Astro.url.searchParams.get('collision');
const done = Astro.url.searchParams.get('done');

const index = await getFileIndex();
const keys = index.map((e) => e.key).sort();
---

<AdminLayout title="Admin">
	<PageHeader title="Dashboard">
		<p slot="subtitle" class="text-sm text-text-secondary">Manage MDX files and edge cache.</p>
	</PageHeader>

	{err ? <p class="mt-5 border border-error/30 bg-error/5 px-4 py-3 font-mono text-sm text-error">Something went wrong (S3 or validation).</p> : null}
	{deleted ? <p class="mt-5 border border-success/30 bg-success/5 px-4 py-3 font-mono text-sm text-success">Object deleted.</p> : null}
	{collision ? <p class="mt-5 border border-error/30 bg-error/5 px-4 py-3 font-mono text-sm text-error">An object with that name already exists.</p> : null}
	{done !== null ? <p class="mt-5 border border-success/30 bg-success/5 px-4 py-3 font-mono text-sm text-success">Removed {done} cache entries (best-effort; false = miss or not stored).</p> : null}

	<div class="mt-8 flex items-baseline justify-between">
		<h2 class="font-mono text-xs uppercase tracking-widest text-text-muted">Objects</h2>
		<a
			href="/admin/edit"
			class="font-mono text-xs text-text-muted transition hover:text-accent"
			transition:animate="none"
		>
			new object &rarr;
		</a>
	</div>

	<ul class="mt-4 border-t border-border">
		{
			keys.length === 0 ? (
				<li class="py-4 font-mono text-xs text-text-muted">// no objects found in mdx/</li>
			) : (
				keys.map((k) => (
					<li class="group flex flex-wrap items-center justify-between gap-3 border-b border-border py-3 transition hover:bg-bg-surface/50 hover:pl-2">
						<a
							class="flex-1 truncate font-mono text-sm text-accent transition group-hover:text-accent-light group-hover:underline underline-offset-2"
							href={`/admin/edit?key=${encodeURIComponent(k)}`}
							transition:animate="none"
						>
							{k}
						</a>
						<form method="POST" action="/api/admin/cms-delete" class="inline" onsubmit="return confirm('Delete this object?')">
							<input type="hidden" name="key" value={k} />
							<button
								type="submit"
								class="shrink-0 font-mono text-xs text-error transition hover:underline underline-offset-2 cursor-pointer"
							>
								delete
							</button>
						</form>
					</li>
				))
			)
		}
	</ul>

	<div class="animate-fade-in-up animate-delay-100 mt-12 border border-error/30 bg-error/5 px-5 py-5">
		<h2 class="font-mono text-xs uppercase tracking-widest text-error">Danger zone</h2>
		<p class="mt-1 font-mono text-xs text-text-muted">Clears all cached public pages derived from the content index.</p>
		<form method="POST" action="/api/admin/purge" class="mt-4" onsubmit="return confirm('Purge all cached pages?')">
			<button
				type="submit"
				class="cursor-pointer border border-error bg-error/10 px-5 py-2 font-display text-sm font-bold text-error transition hover:bg-error/20"
			>
				Purge all cache
			</button>
		</form>
	</div>
</AdminLayout>
