---
import Layout from '@/layouts/Layout.astro';

export const prerender = false;

const done = Astro.url.searchParams.get('done');
const err = Astro.url.searchParams.get('err');
---

<Layout title="Purge cache">
	<div class="animate-fade-in-up space-y-3">
		<h1 class="font-display text-4xl font-bold tracking-tight text-text-primary">Purge edge cache</h1>
		<div class="h-1 w-16 bg-accent"></div>
		<p class="text-text-secondary text-sm">
			Enter paths (e.g. <code class="bg-bg-subtle px-1.5 py-0.5 font-mono text-sm text-accent">/blog</code>) or full URLs, one per line. Uses the same cache keys as public pages (GET, no cookies).
		</p>
	</div>

	{done !== null ? <p class="mt-5 border border-success/30 bg-success/5 px-4 py-3 font-mono text-sm text-success">Removed {done} cache entries (best-effort; false = miss or not stored).</p> : null}
	{err ? <p class="mt-5 border border-error/30 bg-error/5 px-4 py-3 font-mono text-sm text-error">Could not read form.</p> : null}

	<form method="POST" action="/api/admin/purge" class="animate-fade-in-up animate-delay-100 mt-8 space-y-5">
		<label class="block text-sm text-text-secondary">
			<span class="mb-1.5 block font-medium">URLs / paths</span>
			<textarea
				name="urls"
				rows={10}
				placeholder={'/blog\n/blog/my-post'}
				class="w-full border-2 border-border bg-bg-base px-4 py-3 font-mono text-sm text-text-primary outline-none transition focus:border-accent"
			/>
		</label>
		<div class="flex flex-wrap items-center gap-4">
			<button
				type="submit"
				class="bg-accent px-6 py-3 font-display font-bold text-bg-base shadow-[4px_4px_0px_#b0882e] transition-all hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-[6px_6px_0px_#b0882e]"
			>
				Purge
			</button>
			<a href="/admin" class="font-mono text-xs text-text-muted underline underline-offset-4 transition hover:text-text-secondary">← Admin home</a>
		</div>
	</form>
</Layout>
