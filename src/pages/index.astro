---
import Layout from '@/layouts/Layout.astro';
import EntryRow from '@/components/EntryRow.astro';
import { getFileIndex } from '@/lib/file-index';
import { POSTS_PREFIX, slugFromPostKey } from '@/lib/s3';
import { tools } from '@/lib/tools';

export const prerender = false;

const index = await getFileIndex();

const posts = index
	.filter((e) => e.key.startsWith(POSTS_PREFIX) && e.key.endsWith('.mdx'))
	.map((e) => ({
		slug: slugFromPostKey(e.key),
		title: e.title ?? slugFromPostKey(e.key),
		date: e.date ?? '',
	}))
	.sort((a, b) => b.date.localeCompare(a.date))
	.slice(0, 5);

const hasAbout = index.some((e) => e.key === 'mdx/about.mdx');

const buildDate = new Date().toISOString().slice(0, 10);
---

<Layout title="Home" wide={true}>
	<div class="mx-auto max-w-6xl px-4 py-12 lg:py-20">
		<div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
			<!-- Left panel: identity & nav -->
			<div class="animate-slide-in-left-soft space-y-10 lg:col-span-5">
				<div class="space-y-5">
					<h1
						class="font-display text-6xl font-bold tracking-tighter text-text-primary sm:text-7xl lg:text-8xl"
					>
						REMTORI
					</h1>
					<p class="font-mono text-sm text-accent">// systems engineer & writer</p>
					<p class="max-w-sm text-base leading-relaxed text-text-secondary">
						Building things on the internet. Notes on code, infrastructure, and the tools that make it
						all work.
					</p>
				</div>

				<nav class="space-y-3 font-mono text-sm">
					<a
						href="/blog"
						class="group flex items-center gap-2 text-text-secondary transition hover:translate-x-1 hover:text-accent"
						transition:animate="none"
					>
						<span class="text-text-muted">$</span>
						<span>cd</span>
						<span class="text-accent transition group-hover:text-accent-light">~/blog</span>
					</a>
					<a
						href="/about"
						class="group flex items-center gap-2 text-text-secondary transition hover:translate-x-1 hover:text-accent"
						transition:animate="none"
					>
						<span class="text-text-muted">$</span>
						<span>cd</span>
						<span class="text-accent transition group-hover:text-accent-light">~/about</span>
						{!hasAbout && (
							<span class="ml-2 font-mono text-[10px] text-text-muted uppercase">wip</span>
						)}
					</a>
					<a
						href="/tools"
						class="group flex items-center gap-2 text-text-secondary transition hover:translate-x-1 hover:text-accent"
						transition:animate="none"
					>
						<span class="text-text-muted">$</span>
						<span>cd</span>
						<span class="text-accent transition group-hover:text-accent-light">~/tools</span>
					</a>
				</nav>
			</div>

			<!-- Right panel: live data -->
			<div class="space-y-10 lg:col-span-7">
				<!-- Status bar -->
				<div
					class="animate-fade-in-up flex items-center gap-3 border border-border bg-bg-surface px-4 py-2 font-mono text-xs"
				>
					<span class="relative flex h-2 w-2">
						<span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-success opacity-75"></span>
						<span class="relative inline-flex h-2 w-2 rounded-full bg-success"></span>
					</span>
					<span class="text-success">online</span>
					<span class="text-border">—</span>
					<span id="live-clock" class="text-text-muted">--:--:-- UTC</span>
					<span class="ml-auto text-text-muted/60">build: {buildDate}</span>
				</div>

				<!-- Recent Transmissions -->
				<div class="animate-fade-in-up animate-delay-100 space-y-4">
					<div class="flex items-baseline justify-between">
						<h2 class="font-mono text-xs uppercase tracking-widest text-text-muted">
							Recent Transmissions
						</h2>
						<a
							href="/blog"
							class="font-mono text-xs text-text-muted transition hover:text-accent"
							transition:animate="none"
						>
							view all &rarr;
						</a>
					</div>
					<div class="border-t border-border">
						{
							posts.length === 0 ? (
								<div class="py-4 font-mono text-xs text-text-muted">
									// no transmissions found in ~/posts/
								</div>
							) : (
								posts.map((post) => (
									<EntryRow
										href={`/blog/${post.slug}`}
										prefix=">"
										wrapperClass="border-b border-border py-3 transition hover:bg-bg-surface/50 hover:pl-2"
									>
										<span class="w-24 shrink-0 font-mono text-xs text-text-muted">
											{post.date || '----/--/--'}
										</span>
										<span class="truncate font-display text-sm font-medium text-text-primary transition group-hover:text-accent">
											{post.title}
										</span>
									</EntryRow>
								))
							)
						}
					</div>
				</div>

				<!-- Local Utilities -->
				<div class="animate-fade-in-up animate-delay-200 space-y-4">
					<div class="flex items-baseline justify-between">
						<h2 class="font-mono text-xs uppercase tracking-widest text-text-muted">Local Utilities</h2>
						<a
							href="/tools"
							class="font-mono text-xs text-text-muted transition hover:text-accent"
							transition:animate="none"
						>
							view all &rarr;
						</a>
					</div>
					<div class="border-t border-border">
						{
							(() => {
								const popular = tools.filter((t) => t.popular).slice(0, 5);
								return popular.length === 0 ? (
									<div class="py-4 font-mono text-xs text-text-muted">
										// no utilities configured
									</div>
								) : (
									popular.map((tool) => (
										<EntryRow
											prefix=">"
											badge={!tool.href ? 'soon' : undefined}
											wrapperClass="border-b border-border py-3 transition hover:bg-bg-surface/50 hover:pl-2"
										>
											<span class="w-24 shrink-0 font-mono text-xs font-semibold text-text-primary transition group-hover:text-accent">
												{tool.name}
											</span>
											<span class="flex-1 truncate font-mono text-xs text-text-muted">{tool.desc}</span>
										</EntryRow>
									))
								);
							})()
						}
					</div>
				</div>
			</div>
		</div>

		<!-- Footer -->
		<div class="animate-fade-in-up animate-delay-300 mt-20 border-t border-border pt-6 font-mono text-xs text-text-muted">
			/* remtori &copy; {new Date().getFullYear()} — built with astro + cloudflare workers */
		</div>
	</div>

	<script is:inline>
		function updateClock() {
			const el = document.getElementById('live-clock');
			if (!el) return;
			const now = new Date();
			const h = now.getUTCHours().toString().padStart(2, '0');
			const m = now.getUTCMinutes().toString().padStart(2, '0');
			const s = now.getUTCSeconds().toString().padStart(2, '0');
			el.textContent = h + ':' + m + ':' + s + ' UTC';
		}
		updateClock();
		setInterval(updateClock, 1000);
	</script>
</Layout>
