---
import Layout from '@/layouts/Layout.astro';
import MdBody from '@/components/MdBody.astro';
import { loadMdFromS3 } from '@/lib/md-content';
import { postKeyFromSlug } from '@/lib/s3';

export const prerender = false;

const slug = Astro.params.slug;
if (!slug) {
	return Astro.redirect('/blog', 302);
}

const { html, title, date, found } = await loadMdFromS3(postKeyFromSlug(slug));

if (!found) {
	return new Response('Not found', { status: 404, headers: { 'Content-Type': 'text/plain; charset=utf-8' } });
}
---

<Layout {title}>
	<article class="animate-fade-in-up space-y-8">
		<header class="space-y-3">
			<h1 class="font-display text-4xl font-bold tracking-tight text-text-primary sm:text-5xl">{title}</h1>
			<div class="h-1 w-16 bg-accent"></div>
			{date ? <p class="font-mono text-sm text-text-muted">{date}</p> : null}
		</header>
		<MdBody {html} />
	</article>
</Layout>
