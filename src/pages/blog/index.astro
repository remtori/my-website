---
import Layout from '@/layouts/Layout.astro';
import { getFileIndex } from '@/lib/file-index';
import { getEnv } from '@/lib/runtime';
import { POSTS_PREFIX, slugFromPostKey } from '@/lib/s3';

export const prerender = false;

const env = getEnv();
const index = await getFileIndex(env);

const items = index
	.filter((e) => e.key.startsWith(POSTS_PREFIX) && e.key.endsWith('.mdx'))
	.map((e) => ({
		slug: slugFromPostKey(e.key),
		title: e.title ?? slugFromPostKey(e.key),
		date: e.date ?? '',
	}));

items.sort((a, b) => b.date.localeCompare(a.date));
---

<Layout title="Blog">
	<h1 class="text-3xl font-bold text-white">Blog</h1>
	<ul class="mt-8 space-y-4">
		{
			items.length === 0 ? (
				<p class="text-zinc-500">No posts yet. Add `.mdx` files under `mdx/blogs/` in S3, then open a post URL.</p>
			) : (
				items.map((p) => (
					<li class="border-b border-zinc-800 pb-4">
						<a href={`/blog/${p.slug}`} class="text-lg text-amber-400 hover:underline" transition:animate="none">
							{p.title}
						</a>
						{p.date ? <p class="text-sm text-zinc-500">{p.date}</p> : null}
					</li>
				))
			)
		}
	</ul>
</Layout>
