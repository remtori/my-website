---
import { ClientRouter } from 'astro:transitions';
import '@/styles/global.css';

interface Props {
	title: string;
	description?: string;
	wide?: boolean;
}

const { title, description = 'Personal site', wide = false } = Astro.props;
const isAdmin = Astro.url.pathname.startsWith('/admin');
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#0a0d12" />
		<meta name="mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-title" content="Remtori" />
		<title>Remtori - {title}</title>
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="icon" type="image/png" sizes="192x192" href="/android-chrome-192x192.png" />
		<link rel="icon" type="image/png" sizes="512x512" href="/android-chrome-512x512.png" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/manifest.webmanifest" />
		<ClientRouter />
		<script is:inline>
			if ('serviceWorker' in navigator && location.hostname !== 'localhost') {
				navigator.serviceWorker.register('/sw.js');
			}
		</script>
	</head>
	<body class="min-h-screen bg-bg-base text-text-primary font-body antialiased">
		<header class="sticky top-0 z-50 border-b-2 border-accent bg-bg-base">
			<nav class="mx-auto flex max-w-3xl items-center gap-6 px-4 py-4 text-sm">
				<a href="/" class="font-display text-xl font-bold text-accent hover:text-accent-light transition" transition:animate="none">
					Remtori
				</a>
				<div class="flex-1"></div>
				<a href="/" class="text-text-secondary hover:text-text-primary transition underline-offset-4 hover:underline" transition:animate="none">
					Home
				</a>
				<a href="/blog" class="text-text-secondary hover:text-text-primary transition underline-offset-4 hover:underline" transition:animate="none">
					Blog
				</a>
				<a href="/tools" class="text-text-secondary hover:text-text-primary transition underline-offset-4 hover:underline" transition:animate="none">
					Tools
				</a>
				{isAdmin && (
					<span class="border border-accent bg-accent/10 px-2 py-0.5 text-xs font-mono font-bold uppercase tracking-wider text-accent">
						Admin
					</span>
				)}
			</nav>
		</header>
		<main class:list={["px-4 py-12", wide ? "mx-auto max-w-6xl" : "mx-auto max-w-3xl", isAdmin && !wide && "border-l-2 border-accent/60 pl-5"]}>
			<slot />
		</main>
	</body>
</html>
